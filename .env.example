# Copy this file to .env for local testing (never commit .env!)

# ── JIRA ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token        # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=TRANS                    # Your project key (e.g. TRANS, BA, etc.)
JIRA_TRIGGER_STATUS=To Review
JIRA_NEXT_STATUS=In Review

# Translator is read from the JIRA Assignee field (no custom field needed)
# Leave JIRA_TRANSLATOR_FIELD empty unless you have a separate custom field
JIRA_TRANSLATOR_FIELD=

# Optional: custom field ID containing the original article URL
# Leave empty to auto-detect from issue description
JIRA_ORIGINAL_URL_FIELD=

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_BASE_URL=https://ba.in.ua
WP_USERNAME=your-wp-username
# Application password: WP Admin → Users → Profile → Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Anthropic (for tag generation) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
